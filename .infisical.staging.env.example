# =============================================================================
# Template de secretos para Infisical — environment: staging
#
# Importar en: Infisical → proyecto sadday-app → staging → Add Secrets → Import .env
#
# IMPORTANTE: Este archivo es solo un template con placeholders.
# NO commitear con valores reales.
# =============================================================================

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DB_NAME=sadday_staging
DB_USER=sadday_admin
DB_PASSWORD=CHANGE_ME

# ── MinIO (S3 local) ──────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
S3_BUCKET=sadday-staging
S3_REGION=us-east-1

# ── JWT ───────────────────────────────────────────────────────────────────────
# Rutas en el filesystem del runner (Proxmox)
JWT_PRIVATE_KEY_PATH=/opt/sadday/keys/private.pem
JWT_PUBLIC_KEY_PATH=/opt/sadday/keys/public.pem
JWT_ISSUER=sadday-app-staging

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=CHANGE_ME

# ── Aplicación ────────────────────────────────────────────────────────────────
# IP o hostname del servidor Proxmox
APP_URL=http://PROXMOX_IP:3000
MAIL_FROM=noreply@sadday.staging

# ── Admin inicial (solo se usa si la BD está vacía al arrancar) ───────────────
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=CHANGE_ME

# ── Opcionales ────────────────────────────────────────────────────────────────
ADMIN_ALERT_EMAIL=
